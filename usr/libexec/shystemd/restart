# @file       restart
#             restart a given unit
#
# @author     Wes Garland, wes@distributive.network
# @date       Feb 2022, Mar 2026
#

. "${SHYSTEMD_LIB_DIR}"/for-each-unit

restart()
{
  $make unit="$1" -f "${SHYSTEMD_LIB_DIR}"/service.mk restart
}

forEachUnit restart
